{
  "$schema": "https://opencode.ai/config.json",
  "username": "Lin",
  "default_agent": "lin",
  "mcp": {
    "agent-lin": {
      "type": "local",
      "command": ["python", "mcp-servers/agent-lin/server.py"],
      "enabled": true,
      "env": {
        "TAVILY_API_KEY": "${TAVILY_API_KEY}"
      }
    }
  },
  "agent": {
    "lin": {
      "description": "Lin 的个人助手 - 支持搜索问答、以图搜图、网页爬取和文件操作",
      "mode": "primary",
      "permission": {
        "read": "allow",
        "edit": "allow",
        "bash": "allow",
        "glob": "allow",
        "grep": "allow"
      }
    }
  }
}
